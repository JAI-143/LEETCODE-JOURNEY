class Solution:
    def sortByBits(self, arr: List[int]) -> List[int]:
        dabba={}
        for j in arr:
            lp=bin(j).count("1")
            if lp not in dabba:
                dabba[lp]=[j]
            else:
                dabba[lp].append(j)
        vidai=[]
        for j in sorted(list(dabba)):
            vidai+=sorted(dabba[j])
        return vidai
        

        
