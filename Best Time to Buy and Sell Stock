class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        if len(prices)<2:
            return 0
        vidai=0
        s,e=0,1
        op=len(prices)
        while s<op:

            if prices[e] - prices[s] >0:
                vidai=max(vidai,prices[e] - prices[s] ) 
                if e<op-1:

                    e+=1
                else:
                    if s<op-2:
                            
                        s+=1
                        e=s+1
                    else:
                        break

            else:
                if s<op-2:
                        
                    s+=1
                    e=s+1
                else:
                    break
        return vidai






