class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        min_price=float('inf')
        max_profit=0
        for current_price in prices:
            min_price=min(min_price,current_price)
            max_profit=max(max_profit,current_price-min_price)
        return max_profit
 
